#!/usr/bin/env bash
# Bosun CLI — makes sure the right dot-agent-deck config is silently in
# place before you run `dot-agent-deck` yourself. Bosun never launches or
# wraps dot-agent-deck; it only prepares its config.
set -euo pipefail

BOSUN_HOME="$HOME/.bosun"

usage() {
  cat >&2 <<'EOF'
usage: bosun <command>

commands:
  init      generate .dot-agent-deck.toml for the current project
            --agent <cmd>             agent command for all roles
            --orchestrator-cmd <cmd>  override just the orchestrator
            --coder-cmd <cmd>         override just the coder pool
            --scout-cmd <cmd>         override just the scout
            --coder-pool-size <N>     number of parallel coder roles (default: 4)
            (run with no flags in a terminal to be asked interactively)
  status    show whether Bosun is active here and its no-mistakes config state
EOF
  exit 1
}

require_brain() {
  if [ ! -d "$BOSUN_HOME/brain" ]; then
    echo "error: $BOSUN_HOME/brain not found — install Bosun first:" >&2
    echo "  curl -fsSL https://raw.githubusercontent.com/AlienClubrider/bosun/main/install.sh | bash" >&2
    exit 1
  fi
}

repo_name() {
  basename "$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
}

coder_role_block() {
  local name="$1" coder_cmd="$2"
  cat <<EOF
[[orchestrations.roles]]
name = "$name"
command = "$coder_cmd"
description = "Implements features, fixes bugs, refactors code. Isolates its work in its own worktrunk worktree before touching files, and self-validates before signaling done."
prompt_template = """
$(cat "$BOSUN_HOME/brain/POLICY.md")
"""

EOF
}

render_template() {
  local template="$1" orch_cmd="$2" coder_cmd="$3" scout_cmd="$4" pool_size="$5"
  while IFS='' read -r line || [ -n "$line" ]; do
    case "$line" in
      __ORCHESTRATOR_PROMPT__) cat "$BOSUN_HOME/brain/FIRSTMATE.md" ;;
      __CODER_POOL__)
        local i=1
        while [ "$i" -le "$pool_size" ]; do
          coder_role_block "coder-$i" "$coder_cmd"
          i=$((i + 1))
        done
        ;;
      *)
        line="${line//__ORCHESTRATOR_COMMAND__/$orch_cmd}"
        line="${line//__SCOUT_COMMAND__/$scout_cmd}"
        printf '%s\n' "$line"
        ;;
    esac
  done < "$template"
}

cmd_init() {
  require_brain

  local agent="" orch_cmd="" coder_cmd="" scout_cmd="" pool_size=4
  while [ $# -gt 0 ]; do
    case "$1" in
      --agent) agent="$2"; shift 2 ;;
      --orchestrator-cmd) orch_cmd="$2"; shift 2 ;;
      --coder-cmd) coder_cmd="$2"; shift 2 ;;
      --scout-cmd) scout_cmd="$2"; shift 2 ;;
      --coder-pool-size) pool_size="$2"; shift 2 ;;
      *) echo "error: unknown flag $1" >&2; exit 1 ;;
    esac
  done

  case "$pool_size" in
    ''|*[!0-9]*|0) echo "error: --coder-pool-size must be a positive integer" >&2; exit 1 ;;
  esac

  # Workers run autonomously in their own disposable worktree, so the
  # default trusts them the way a launched CLI agent normally isn't:
  # bypassPermissions, so routine actions (creating the worktree, running
  # tests, running no-mistakes) don't block on a prompt sitting in a pane
  # nobody's watching. The worktree, plus POLICY.md's own "never merge,
  # never push, nothing outside the worktree" rules, are the safety net
  # instead. Override with --orchestrator-cmd/--coder-cmd/--scout-cmd (or
  # --agent for all three) if you want tighter control on a given role.
  local default_cmd="claude --permission-mode bypassPermissions"
  [ -n "$agent" ] && default_cmd="$agent"

  if [ -z "$agent" ] && [ -z "$orch_cmd" ] && [ -z "$coder_cmd" ] && [ -z "$scout_cmd" ] && [ -t 0 ]; then
    printf 'Agent command to run for each role [%s]: ' "$default_cmd" >&2
    read -r reply
    [ -n "$reply" ] && default_cmd="$reply"
  fi

  orch_cmd="${orch_cmd:-$default_cmd}"
  coder_cmd="${coder_cmd:-$default_cmd}"
  scout_cmd="${scout_cmd:-$default_cmd}"

  if ! git rev-parse --git-dir >/dev/null 2>&1; then
    echo "error: not a git repository" >&2
    exit 1
  fi

  local out=".dot-agent-deck.toml"
  if [ -e "$out" ] && ! grep -q "bosun:managed" "$out" 2>/dev/null; then
    echo "error: $out already exists and wasn't generated by Bosun — remove it first if you want Bosun to manage it." >&2
    exit 1
  fi

  render_template "$BOSUN_HOME/brain/dot-agent-deck.toml" "$orch_cmd" "$coder_cmd" "$scout_cmd" "$pool_size" > "$out"

  local exclude_file exclude_line
  exclude_file="$(git rev-parse --git-dir)/info/exclude"
  exclude_line="/.dot-agent-deck.toml"
  mkdir -p "$(dirname "$exclude_file")"
  touch "$exclude_file"
  if ! grep -qxF "$exclude_line" "$exclude_file"; then
    echo "$exclude_line" >> "$exclude_file"
  fi

  echo "Bosun is active in this project. Run \`dot-agent-deck\` to start."
}

cmd_status() {
  if [ -e .dot-agent-deck.toml ] && grep -q "bosun:managed" .dot-agent-deck.toml 2>/dev/null; then
    echo "Bosun: active in $(pwd)"
  else
    echo "Bosun: not initialized here (run \`bosun init\`)"
  fi

  local repo config
  repo="$(repo_name)"
  config="$BOSUN_HOME/no-mistakes/$repo.yaml"
  if [ -f "$config" ]; then
    echo "no-mistakes config: $config"
  else
    echo "no-mistakes config: none for '$repo' — using defaults"
  fi
}

[ $# -ge 1 ] || usage
case "$1" in
  init) shift; cmd_init "$@" ;;
  status) shift; cmd_status "$@" ;;
  *) usage ;;
esac
